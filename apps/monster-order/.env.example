# Shisha MONSTER 発注アプリ — 環境変数

# 対象Shopifyストアのドメイン（カタログ/カートパーマリンクに使用）。
# シーシャモンスターが公開されたら shisha-monster.com に切替。
# 現在SMはパスワード保護中のため、検証は公開中のNEWEMOで可能。
NEXT_PUBLIC_MONSTER_SHOP_DOMAIN=newemoshisha.com

# --- OCR（棚写真の文字読み取り）。どちらか片方を設定すれば動く ---
# 推奨: Google AI Studio の Gemini キー（無料枠・クレジットカード不要）。
#   取得: https://aistudio.google.com/apikey → Create API key
#   OCR＋「商品名 x数量」への整形まで一発。サーバー側のみ（NEXT_PUBLIC_にしない）。
# MONSTER_GEMINI_API_KEY=

# 代替: Google Cloud Vision の APIキー（要・GCP課金/カード）。
#   Cloud Console で「Cloud Vision API」を有効化→APIキー作成。
# MONSTER_OCR_API_KEY=

# どちらも未設定でも、手入力での在庫登録は可能です。
