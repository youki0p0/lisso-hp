# Shisha MONSTER 発注アプリ — 環境変数

# 対象Shopifyストアのドメイン（カタログ/カートパーマリンクに使用）。
# シーシャモンスターが公開されたら shisha-monster.com に切替。
# 現在SMはパスワード保護中のため、検証は公開中のNEWEMOで可能。
NEXT_PUBLIC_MONSTER_SHOP_DOMAIN=newemoshisha.com

# 実OCR（Google Cloud Vision）APIキー。サーバー側のみ（NEXT_PUBLIC_にしない）。
# 未設定だと /api/ocr は 501 を返す（手入力は可能）。
# MONSTER_OCR_API_KEY=
